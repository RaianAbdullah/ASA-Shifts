# ASA Workforce Backend — Environment Variables Example
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# NEVER use these example values in production.

# ===== Spring Profile =====
SPRING_PROFILES_ACTIVE=development

# ===== Server =====
PORT=8080

# ===== Database (Stage 2+) =====
# Replit provides DATABASE_URL automatically.
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# ===== Redis (Stage 3+) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme-in-production
REDIS_SSL=false

# ===== JWT Secrets (Stage 4+) =====
# REQUIRED in production. Must be cryptographically random, >= 64 characters.
# Generate with: openssl rand -hex 64
JWT_ISSUER=asa-workforce
JWT_AUDIENCE=asa-mobile-app
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=3

# ===== OTP Settings (Stage 3+) =====
OTP_EXPIRATION_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ===== Email Provider (Stage 3+) =====
EMAIL_PROVIDER_HOST=smtp.example.com
EMAIL_PROVIDER_PORT=587
EMAIL_PROVIDER_USERNAME=
EMAIL_PROVIDER_PASSWORD=

# ===== SMS Provider (optional, Stage 3+) =====
SMS_PROVIDER_KEY=

# ===== CORS (Stage 5+) =====
# Comma-separated list of allowed origins. Wildcard only for development.
ALLOWED_CORS_ORIGINS=*

# ===== File Storage (Stage 9+) =====
FILE_STORAGE_PATH=/tmp/asa-uploads
MAX_UPLOAD_SIZE_MB=10
